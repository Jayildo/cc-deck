{
  "name": "cc-deck",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local mission-control for multiple Claude Code CLI sessions: live terminals, per-session context + tokens, and account 5h/weekly usage.",
  "scripts": {
    "dev": "concurrently -n server,web -c blue,magenta \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:web": "vite",
    "build": "vite build",
    "start": "cross-env NODE_ENV=production tsx server/index.ts",
    "install:statusline": "node scripts/install-statusline-tee.mjs",
    "uninstall:statusline": "node scripts/uninstall-statusline-tee.mjs",
    "install:autostart": "node scripts/install-autostart.mjs",
    "uninstall:autostart": "node scripts/uninstall-autostart.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/static": "^8.0.4",
    "@fastify/websocket": "^11.0.2",
    "@lydell/node-pty": "^1.2.0-beta.12",
    "chokidar": "^4.0.3",
    "fastify": "^5.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.1",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^6.1.0"
  }
}
